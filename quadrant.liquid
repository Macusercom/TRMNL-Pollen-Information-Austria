{% assign entries = contamination | sort: "contamination_1" | reverse %}
{% assign pollen_filter = trmnl.plugin_settings.custom_fields_values.pollen_filter | default: "" | strip %}
{% assign filter_list = pollen_filter | split: "," %}

{% assign active_count = 0 %}
{% for entry in entries %}
  {% if entry.contamination_1 == 0 %}{% continue %}{% endif %}
  {% if pollen_filter != "" %}
    {% assign entry_name = entry.poll_title | split: " (" | first | downcase %}
    {% assign match = false %}
    {% for f in filter_list %}
      {% assign f_clean = f | strip | downcase %}
      {% if entry_name contains f_clean %}{% assign match = true %}{% endif %}
    {% endfor %}
    {% unless match %}{% continue %}{% endunless %}
  {% endif %}
  {% assign active_count = active_count | plus: 1 %}
{% endfor %}

<div class="layout layout--col gap--small">
  {% if entries.size == 0 %}
    <div class="flex flex--col flex--center flex--center-x gap stretch-x">
      <span class="value value--xxlarge">✕</span>
      <span class="label label--large">Keine Pollendaten verfügbar</span>
    </div>
  {% elsif active_count == 0 %}
    <div class="flex flex--col flex--center flex--center-x gap stretch-x">
      <span class="value value--xxlarge">✓</span>
      <span class="label label--large">Keine Pollenbelastung</span>
    </div>
  {% else %}
    <div class="grid grid--cols-2 gap--small stretch-x" data-overflow="true" data-overflow-counter="true">
      {% for entry in entries %}
        {% assign d1 = entry.contamination_1 | default: 0 | plus: 0 %}

        {% if d1 == 0 %}{% continue %}{% endif %}

        {% if pollen_filter != "" %}
          {% assign entry_name = entry.poll_title | split: " (" | first | downcase %}
          {% assign match = false %}
          {% for f in filter_list %}
            {% assign f_clean = f | strip | downcase %}
            {% if entry_name contains f_clean %}{% assign match = true %}{% endif %}
          {% endfor %}
          {% unless match %}{% continue %}{% endunless %}
        {% endif %}

        {% assign emphasis = "" %}
        {% if d1 >= 3 %}
          {% assign emphasis = " item--emphasis-3" %}
        {% elsif d1 == 2 %}
          {% assign emphasis = " item--emphasis-2" %}
        {% elsif d1 == 1 %}
          {% assign emphasis = " item--emphasis-1" %}
        {% endif %}

        <div class="item{{ emphasis }}">
          <div class="meta"></div>
          <div class="content">
            <span class="title title--small" data-clamp="1">{{ entry.poll_title | split: " (" | first }}</span>
            <span class="value value--small value--tnums">{{ d1 }}</span>
            <span class="label label--small label--gray">
              {% if d1 == 1 %}gering{% elsif d1 == 2 %}mäßig{% elsif d1 == 3 %}stark{% else %}sehr stark{% endif %}
            </span>
          </div>
        </div>
      {% endfor %}
    </div>
  {% endif %}
</div>

<div class="title_bar">
  <img class="image" src="{{ title_bar_icon }}">
  <span class="title">Pollen heute</span>
  <span class="instance">polleninformation.at</span>
</div>
